# Base URL of the backend REST API.
VITE_API_BASE_URL=http://localhost:8080

# Optional. Only needed if the backend has APP_CONFIG_API_KEY set: the panel then sends it
# as the X-Api-Key header on POST /api/config. Leave blank otherwise.
# Note: a key bundled into a public SPA is a minimal anti-abuse barrier, not a real secret.
VITE_CONFIG_API_KEY=
